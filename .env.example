# Database URL for Supabase/Postgres.
# For Prisma with Supabase, prefer the pooler URL for runtime queries and a direct
# connection in DIRECT_URL for migrations when available. If you do not yet have
# the direct connection string, use the pooler temporarily.
# The pooler can require `sslmode=no-verify` in local environments depending on
# the local trust store.
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=no-verify"
DIRECT_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=no-verify"

# Google Gemini API Key for PDF parsing
# Get your API key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# Supabase (optional - for cloud storage)
# NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
