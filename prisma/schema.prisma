generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  DEBIT_CARD
  CASH
  OTHER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum BillingCycle {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Account {
  id          String   @id @default(cuid())
  name        String
  type        AccountType
  bank        String?
  color       String   @default("#3B82F6")
  icon        String?
  initialBalance Float @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  statements  Statement[]
  transactions Transaction[]
  subscriptions Subscription[]
}

model Statement {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  fileName    String
  fileUrl     String?
  uploadedAt  DateTime @default(now())
  transactions Transaction[]
  
  @@unique([accountId, month, year])
}

model Category {
  id           String   @id @default(cuid())
  name         String
  color        String   @default("#6B7280")
  icon         String?
  parentId     String?
  parent       Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     Category[] @relation("CategoryHierarchy")
  transactions Transaction[]
  subscriptions Subscription[]
  rules        CategorizationRule[]
  isSystem     Boolean  @default(false)
  budget       Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([name])
}

model CategorizationRule {
  id          String   @id @default(cuid())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  keywords    String
  matchType   String   @default("contains")
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([categoryId])
}

model Transaction {
  id            String          @id @default(cuid())
  accountId     String
  account       Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  statementId   String?
  statement     Statement?      @relation(fields: [statementId], references: [id], onDelete: SetNull)
  categoryId    String?
  category      Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  type          TransactionType @default(EXPENSE)
  amount        Float
  description   String
  date          DateTime
  isRecurring   Boolean         @default(false)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  @@index([accountId, date])
  @@index([categoryId])
  @@index([date])
}

model Subscription {
  id              String       @id @default(cuid())
  name            String
  logo            String?
  price           Float
  currency        String       @default("USD")
  billingCycle    BillingCycle @default(MONTHLY)
  frequency       Int          @default(1) // Every X days/weeks/months/years
  nextPayment     DateTime
  autoRenew       Boolean      @default(true)
  inactive        Boolean      @default(false)
  url             String?
  notes           String?
  categoryId      String?
  category        Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  accountId       String?
  account         Account?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  replacementId   String?      // ID of subscription that replaced this one

  // Auto-detection fields
  source         String    @default("manual")  // "manual" | "detected"
  matchPattern   String?                       // Normalized description used for matching
  lastSeenDate   DateTime?                     // Most recent matching transaction date
  firstSeenDate  DateTime?                     // Earliest matching transaction date
  occurrences    Int       @default(0)         // Number of matched transactions
  avgAmount      Float?                        // Average amount across matched transactions

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([nextPayment])
  @@index([inactive])
  @@index([matchPattern])
}

model Settings {
  id          String   @id @default("default")
  geminiApiKey String?
  geminiChatModel String @default("gemini-2.5-flash")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatSession {
  id        String   @id @default(cuid())
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  ChatMessage[]
  
  @@index([createdAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // "user" or "assistant"
  content   String
  createdAt DateTime @default(now())
  
  @@index([sessionId])
  @@index([createdAt])
}
